// Conversions
fn degrees(radians) {
    ret radians * 180 / PI
}

fn radians(degrees) {
    ret degrees * PI / 180
}

// GCD and LCM
fn gcd(a, b) {
    fe (b == 0) {
        ret a
    }
    ret gcd(b, a % b)
}

fn lcm(a, b) {
    ret (a * b) / gcd(a, b)
}

// Factorial
fn factorial(n) {
    fe (n <= 1) {
        ret 1
    }
    ret n * factorial(n - 1)
}

// Fibonacci
fn fibonacci(n) {
    fe (n <= 1) {
        ret n
    }
    ret fibonacci(n - 1) + fibonacci(n - 2)
}

