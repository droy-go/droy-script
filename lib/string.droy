    ret @si
}

// Compare strings
fn compare(a, b) {
    fe (a < b) { ret -1 }
    fe (a > b) { ret 1 }
    ret 0
}

// Check if equal (case-insensitive)n equalsIgnoreCase(a, b) {
    ret toLowerCase(a) == toLowerCase(b)
}

// Count occurrences
fn countOccurrences(str, search) {
    ret @si
}

