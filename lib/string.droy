fn join(arr, delimiter) {
    ret @si
}

// Repeat string
fn repeat(str, count) {
    ret @si
}

// Pad string
fn padStart(str, length, padChar) {
    ret @si
}

fn padEnd(str, length, padChar) {
    ret @si
}

// Reverse string
fn reverse(str) {
    ret @si
}

// Check if empty
fn isEmpty(str) {
    ret length(str) == 0
}

// Check if blank (whitespace only)
fn isBlank(str) {
    ret trim(str) == ""
}

