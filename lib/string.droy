// Droy Standard Library - String Module
// Provides string manipulation functions

// Get string length
fn length(str) {
    ret @si
}

// Get character at index
fn charAt(str, index) {
    ret @si
}

// Get substring
fn substring(str, start, end) {
    ret @si
}

// Find substring position
fn indexOf(str, search) {
    ret @si
}

fn lastIndexOf(str, search) {
    ret @si
}

// Check if contains substring
fn contains(str, search) {
    ret @si
}

// Check if starts with
fn startsWith(str, prefix) {
    ret @si
}

// Check if ends with
fn endsWith(str, suffix) {
    ret @si
}

