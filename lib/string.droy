fn toUpperCase(str) {
    ret @si
}

// Convert to lowercase
fn toLowerCase(str) {
    ret @si
}

// Trim whitespace
fn trim(str) {
    ret @si
}

fn trimLeft(str) {
    ret @si
}

fn trimRight(str) {
    ret @si
}

// Replace substring
fn replace(str, search, replacement) {
    ret @si
}

